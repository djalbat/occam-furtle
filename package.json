{
  "name": "occam-furtle",
  "author": "James Smith",
  "version": "3.0.397",
  "license": "MIT, Anti-996",
  "homepage": "https://github.com/djalbat/occam-furtle",
  "description": "Occam's Furtle language.",
  "repository": {
    "type": "git",
    "url": "https://github.com/djalbat/occam-furtle"
  },
  "dependencies": {
    "necessary": "^17.5.2",
    "occam-grammars": "^1.3.632",
    "occam-languages": "^2.1.23",
    "occam-lexers": "^23.2.2",
    "occam-parsers": "^23.2.4",
    "occam-query": "^4.1.198"
  },
  "devDependencies": {
    "@swc/core": "1.13.20",
    "decaf-cli": "^1.0.33",
    "easy": "^25.0.8",
    "easy-layout": "^6.0.330",
    "easy-with-style": "^3.0.574",
    "esbuild": "0.11.14",
    "express": "^4.17.1",
    "juxtapose": "^4.0.143",
    "lively-cli": "^3.0.3",
    "occam-grammar-utilities": "^8.1.17",
    "occam-model": "^1.0.561",
    "occam-server": "^7.0.61",
    "watchful-cli": "^1.7.102"
  },
  "scripts": {
    "start": "node ./bin/main.js",
    "clean": "rm -rf ./lib",
    "watchful": "watchful -m --transpiler=swc --bundler=esbuild --source-directory=./src --lib-directory=./lib --entry-file=example.js --bundle-file=./example.js --wait=100",
    "batch": "npm run watchful batch --",
    "batch-debug": "npm run watchful batch -- --debug",
    "incremental": "npm run watchful incremental --",
    "incremental-debug": "npm run watchful incremental -- --debug",
    "build": "npm run clean && npm run batch",
    "build-debug": "npm run clean && npm run batch-debug",
    "watch": "npm run clean && npm run batch && npm run incremental",
    "watch-debug": "npm run clean && npm run batch-debug && npm run incremental-debug",
    "test": "decaf test -f"
  },
  "files": [
    "src",
    "lib"
  ],
  "main": "./lib/index.js"
}
